;profile_delete_dialog_message,49,V2011864dc,7e01186558,;"Ertu viss um að þú viljir eyða '%s'?";profile_delete_dialog_message,50,V200ec4731,5d00ec478c,;"Sei sicuro di voler eliminare '%s'?";profile_delete_dialog_message,51,V200ec3f9d,5f00ec3ffa,;"האם אתה בטוח שאתה רוצה למחוק את '%s'?";profile_delete_dialog_message,52,V200ec38f7,4500ec393a,;"%sを削除してよいですか?";profile_delete_dialog_message,53,V2012e6dd9,8e012e6e65,;"დარწმუნებული ხართ\, რომ '%s'-ის წაშლის სურვილი გაქვთ?";profile_delete_dialog_message,54,V200ec383e,4e00ec388a,;"삭제하려는 항목이 맞습니까 '%s'?";profile_delete_dialog_message,55,V201526a9e,7801526b14,;"ທ່ານແນ່ໃຈບໍວ່າຕ້ອງການລຶບ '%s'?";profile_delete_dialog_message,56,V200ee6834,7700ee68a9,;"Ar tikrai norite ištrinti „%s“?";profile_delete_dialog_message,57,V201176a65,7901176adc,;"Vai tiešām vēlaties dzēst '%s'?";profile_delete_dialog_message,58,V200ee5ed1,9300ee5f62,;"Дали сте сигурни дека сакате да го избришете профилот „%s“?";profile_delete_dialog_message,59,V201286641,7e012866bd,;"Er du sikker på at du vil slette «%s»?";profile_delete_dialog_message,60,V200ee66ba,8a00ee6742,;"के तपाईं साँच्चै '%s' प्रोफाइल हटाउन चाहनुहुन्छ?";profile_delete_dialog_message,61,V200ec47a4,6300ec4805,;"Weet u zeker dat u '%s' wilt verwijderen?";profile_delete_dialog_message,62,V200ec4566,5a00ec45be,;"Czy na pewno chcesz usunąć '%s'?";profile_delete_dialog_message,63,V200ec4605,6100ec4664,;"Tem certeza de que deseja excluir '%s'?";profile_delete_dialog_message,64,V200ec44f6,6100ec4555,;"Tem certeza de que deseja excluir '%s'?";profile_delete_dialog_message,65,V200ee6349,8300ee63ca,;"Ești sigur că vrei să ștergi profilul „%s”?";profile_delete_dialog_message,66,V200ec4551,5c00ec45ab,;"Вы уверены\, что хотите удалить «%s»?";profile_delete_dialog_message,67,V201286911,8501286994,;"Ste si istý\, že chcete odstrániť profil „%s“?";profile_delete_dialog_message,68,V2013568c0,8701356945,;"Ali ste prepričani\, da želite izbrisati '%s'?";profile_delete_dialog_message,69,V2012f6804,8c012f688e,;"Da li ste sigurni da želite da obrišete profil „%s“?";profile_delete_dialog_message,70,V20128697d,82012869fd,;"Är du säker på att du vill ta bort \"%s\"?";profile_delete_dialog_message,71,V200ef69d2,8800ef6a58,;"'%s' என்ற சுயவிவரத்தை நீக்க விரும்புகிறீர்களா?";profile_delete_dialog_message,72,V200ee61f4,7b00ee626d,;"คุณแน่ใจหรือไม่ว่าต้องการลบ '%s'?";profile_delete_dialog_message,73,V200ee650a,9200ee659a,;"'%s' profiliňi ýok etmek isleýändigizden ynanýarsyňyzmy?";profile_delete_dialog_message,74,V2012c68bd,8f012c694a,;"'%s' adlı profili silmek istediğinizden emin misiniz?";profile_delete_dialog_message,75,V200ec474f,5d00ec47aa,;"Ви впевнені\, що хочете видалити «%s»?";profile_delete_dialog_message,76,V200ec44b5,5a00ec450d,;"Bạn có chắc muốn xóa '%s' không?";profile_delete_dialog_message,77,V200ec34cf,4400ec3511,;"您确定要删除“%s”吗？";profile_delete_dialog_message,78,V200ee53ba,6400ee541c,;"你確定要刪除「%s」嗎？";profile_delete_dialog_message,79,V200ec34e6,4400ec3528,;"您確定要刪除「%s」嗎？";label_custom_scheme,28,V1032ac082,35032ac0b6,;"Custom";label_custom_scheme,29,V2014c8b4c,56014c8ba0,;"Aangepas";label_custom_scheme,30,V2014a5caa,32014a5cda,;"مخصص";label_custom_scheme,31,V2014c8f0e,74014c8f80,;"Карыстальніцкі/ствараны карыстальнікам";label_custom_scheme,32,V2014c8d36,6a014c8d9e,;"Потребителски/Персонализиран";label_custom_scheme,33,V2014a6267,3b014a62a0,;"Personalitzat";label_custom_scheme,34,V2014a5d64,35014a5d97,;"Vlastní";label_custom_scheme,35,V2014d7888,5d014d78e3,;"Brugerdefineret";label_custom_scheme,36,V2014a62b7,3f014a62f4,;"Benutzerdefiniert";label_custom_scheme,37,V20172848b,5b017284e4,;"Προσαρμοσμένο";label_custom_scheme,82,V200130492,58001304e8,;"Customised";label_custom_scheme,38,V2014a63ae,3b014a63e7,;"Personalizado";label_custom_scheme,39,V201727de0,5d01727e3b,;"Pertsonalizatua";label_custom_scheme,40,V2014a602e,34014a6060,;"سفارشی";label_custom_scheme,41,V2016a7fe8,58016a803e,;"Mukautettu";label_custom_scheme,42,V2014a6435,3a014a646d,;"Personnalisé";label_custom_scheme,43,V20172